<UserControl x:Class="DhCodetaskExtension.ToolWindows.TrackerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" d:DesignHeight="1100" d:DesignWidth="340">

    <UserControl.Resources>
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="Margin" Value="0,10,0,4"/>
        </Style>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
        </Style>
        <Style x:Key="BigBtn" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
        </Style>
        <Style x:Key="UtilBtn" TargetType="Button">
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="7,0"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
        </Style>
        <!-- Style nhỏ cho nút copy inline -->
        <Style x:Key="CopyBtn" TargetType="Button">
            <Setter Property="Height" Value="20"/>
            <Setter Property="Width" Value="20"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="4,0,0,0"/>
            <Setter Property="ToolTip" Value="Copy"/>
            <Setter Property="Content" Value="📋"/>
        </Style>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="10,10,10,14">

            <!-- Title -->
            <TextBlock Text="🎯 DevTask Tracker" FontWeight="Bold" FontSize="14" Margin="0,0,0,2"/>
            <TextBlock Text="{Binding StatusMessage, Mode=OneWay}" FontSize="10" Foreground="#555"
                       TextWrapping="Wrap" Margin="0,0,0,8"/>

            <!-- ── URL Bar ───────────────────────────────────────────── -->
            <TextBlock Text="── 🔗 Task URL ──" Style="{StaticResource SectionLabel}"/>
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="Clear" Style="{StaticResource ActionBtn}"
                        Command="{Binding ClearCommand}" Width="50" Margin="4,0,0,0"/>
                <Button DockPanel.Dock="Right" Content="Fetch" Style="{StaticResource ActionBtn}"
                        Command="{Binding FetchCommand}" Width="55"/>
                <Button DockPanel.Dock="Right" Content="🔗" Width="28" Height="26" FontSize="13"
                        x:Name="BtnOpenUrl" Click="BtnOpenUrl_Click"
                        ToolTip="Mở URL trong browser mặc định" Margin="4,0,0,0"/>
                <TextBox Text="{Binding TaskUrl, UpdateSourceTrigger=PropertyChanged}"
                         Height="26" FontSize="11" Padding="4,2" VerticalContentAlignment="Center"
                         ToolTip="URL issue Gitea, ví dụ: http://localhost:3000/owner/repo/issues/1"/>
            </DockPanel>

            <!-- ── Task Info ─────────────────────────────────────────── -->
            <TextBlock Text="── 📌 Thông tin Task ──" Style="{StaticResource SectionLabel}"/>
            <TextBox Text="{Binding TaskTitle, UpdateSourceTrigger=PropertyChanged}"
                     Height="26" FontSize="12" FontWeight="SemiBold" Padding="4,2"
                     VerticalContentAlignment="Center" Margin="0,0,0,4"/>
            <TextBlock Text="{Binding LabelsDisplay, Mode=OneWay}" FontSize="10" Foreground="#007ACC"
                       Margin="0,0,0,4" TextWrapping="Wrap"/>

            <!-- v3.10: Creator info (hiển thị khi có dữ liệu) -->
            <Border Visibility="{Binding HasCreatorInfo, Converter={StaticResource BoolVis}}"
                    Background="#F0F8FF" BorderBrush="#B0D8FF" BorderThickness="1"
                    CornerRadius="3" Padding="6,4" Margin="0,0,0,4">
                <WrapPanel>
                    <TextBlock FontSize="10" Foreground="#555">
                        <Run Text="👤 Tạo bởi: "/>
                        <Run Text="{Binding CreatedByUser, Mode=OneWay}" FontWeight="SemiBold"/>
                    </TextBlock>
                    <TextBlock FontSize="10" Foreground="#555" Margin="10,0,0,0"
                               Visibility="{Binding HasCreatorInfo, Converter={StaticResource BoolVis}}">
                        <Run Text="📅 "/>
                        <Run Text="{Binding CreatedAt, Mode=OneWay}"/>
                    </TextBlock>
                </WrapPanel>
            </Border>

            <TextBox Text="{Binding TaskDescription, UpdateSourceTrigger=PropertyChanged}"
                     Height="50" FontSize="11" Padding="4" AcceptsReturn="True"
                     TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>

            <!-- ── v3.10: Connection Info ───────────────────────────────── -->
            <Border Visibility="{Binding HasConnInfo, Converter={StaticResource BoolVis}}"
                    Background="#F5FFF5" BorderBrush="#A5D6A7" BorderThickness="1"
                    CornerRadius="3" Padding="8,6" Margin="0,6,0,0">
                <StackPanel>
                    <TextBlock Text="🔌 Thông tin kết nối" FontSize="10" FontWeight="SemiBold"
                               Foreground="#2E7D32" Margin="0,0,0,4"/>

                    <!-- IP Server — chỉ hiển thị khi có giá trị -->
                    <DockPanel Margin="0,0,0,2"
                               Visibility="{Binding HasConnIpServer, Converter={StaticResource BoolVis}}">
                        <Button DockPanel.Dock="Right" Style="{StaticResource CopyBtn}"
                                Command="{Binding CopyIpCommand}"/>
                        <TextBlock FontSize="11" VerticalAlignment="Center">
                            <Run Text="🖥 IP: " Foreground="#555"/>
                            <Run Text="{Binding ConnIpServer, Mode=OneWay}" FontFamily="Consolas"
                                 FontWeight="SemiBold" Foreground="#1B5E20"/>
                        </TextBlock>
                    </DockPanel>

                    <!-- Database — chỉ hiển thị khi có giá trị -->
                    <DockPanel Margin="0,0,0,2"
                               Visibility="{Binding HasConnDatabase, Converter={StaticResource BoolVis}}">
                        <Button DockPanel.Dock="Right" Style="{StaticResource CopyBtn}"
                                Command="{Binding CopyDbCommand}"/>
                        <TextBlock FontSize="11" VerticalAlignment="Center">
                            <Run Text="🗄 DB:  " Foreground="#555"/>
                            <Run Text="{Binding ConnDatabase, Mode=OneWay}" FontFamily="Consolas"
                                 FontWeight="SemiBold" Foreground="#1B5E20"/>
                        </TextBlock>
                    </DockPanel>

                    <!-- Port — chỉ hiển thị khi có giá trị -->
                    <DockPanel Visibility="{Binding HasConnPort, Converter={StaticResource BoolVis}}">
                        <Button DockPanel.Dock="Right" Style="{StaticResource CopyBtn}"
                                Command="{Binding CopyPortCommand}"/>
                        <TextBlock FontSize="11" VerticalAlignment="Center">
                            <Run Text="🔌 Port:" Foreground="#555"/>
                            <Run Text="{Binding ConnPort, Mode=OneWay}" FontFamily="Consolas"
                                 FontWeight="SemiBold" Foreground="#1B5E20"/>
                        </TextBlock>
                    </DockPanel>
                </StackPanel>
            </Border>

            <!-- ── Task Timer ─────────────────────────────────────────── -->
            <TextBlock Text="── ⏱ Task Timer ──" Style="{StaticResource SectionLabel}"/>
            <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="4" Padding="8">
                <StackPanel>
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Right" Text="{Binding TimerState, Mode=OneWay}"
                                   FontSize="10" Foreground="#888" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding TimerDisplay, Mode=OneWay}" FontSize="22"
                                   FontFamily="Consolas" FontWeight="Bold" Foreground="#007ACC"/>
                    </DockPanel>
                    <WrapPanel Margin="0,8,0,0">
                        <Button Content="▶ Bắt đầu"  Style="{StaticResource BigBtn}"
                                Padding="14,0" Command="{Binding StartCommand}"
                                ToolTip="Bắt đầu hoặc tiếp tục tính giờ"/>
                        <Button Content="⏸ Tạm ngưng" Style="{StaticResource BigBtn}"
                                Padding="14,0" Command="{Binding PauseCommand}"
                                ToolTip="Tạm ngưng và ghi nhận lý do"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- ── Work Notes ────────────────────────────────────────── -->
            <TextBlock Text="── 📝 Work Notes ──" Style="{StaticResource SectionLabel}"/>
            <TextBox Text="{Binding WorkNotes, UpdateSourceTrigger=PropertyChanged}"
                     Height="70" FontSize="11" Padding="4" AcceptsReturn="True"
                     TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>

            <!-- ── TODO List ──────────────────────────────────────────── -->
            <TextBlock Text="── ✅ TODO List ──" Style="{StaticResource SectionLabel}"/>

            <Expander Header="📋 Chọn nhanh từ mẫu" FontSize="10" Margin="0,0,0,6"
                      IsExpanded="True"
                      Visibility="{Binding HasTodoTemplates, Converter={StaticResource BoolVis}}">
                <Border Background="#F8F8F8" BorderBrush="#E0E0E0" BorderThickness="1"
                        CornerRadius="3" Padding="6,6">
                    <StackPanel>
                        <TextBlock Text="Nhấn để điền vào ô bên dưới, sau đó nhấn Add:"
                                   FontSize="9" Foreground="#999" Margin="0,0,0,4"/>
                        <ItemsControl ItemsSource="{Binding TodoTemplates}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding}" FontSize="10" Height="24"
                                            Padding="8,0" Margin="0,0,4,4"
                                            ToolTip="{Binding}"
                                            Command="{Binding DataContext.AddTodoFromTemplateCommand,
                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Expander>

            <!-- New TODO input -->
            <DockPanel Margin="0,0,0,4">
                <Button DockPanel.Dock="Right" Content="Add" Width="45" Height="26"
                        FontSize="11" Command="{Binding AddTodoCommand}" Margin="4,0,0,0"/>
                <TextBox Text="{Binding NewTodoText, UpdateSourceTrigger=PropertyChanged}"
                         Height="26" FontSize="11" Padding="4,2" VerticalContentAlignment="Center"
                         ToolTip="Nhập nội dung TODO rồi nhấn Add hoặc Enter">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Return" Command="{Binding AddTodoCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>
            </DockPanel>

            <ItemsControl ItemsSource="{Binding Todos, Mode=OneWay}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#EEE" BorderThickness="0,0,0,1" Padding="0,5">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding Text, Mode=OneWay}" FontSize="11"
                                               TextWrapping="Wrap">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsDone}" Value="True">
                                                        <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                        <Setter Property="Foreground" Value="#888"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="{Binding ElapsedDisplay, Mode=OneWay}" FontSize="10"
                                               Foreground="#007ACC" FontFamily="Consolas"/>
                                </StackPanel>
                                <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                                    <Button Content="▶" Width="24" Height="24" FontSize="10" Margin="1"
                                            Command="{Binding StartCommand}"
                                            ToolTip="Bắt đầu (chỉ khi task cha đang chạy)"/>
                                    <Button Content="⏸" Width="24" Height="24" FontSize="10" Margin="1"
                                            Command="{Binding PauseCommand}" ToolTip="Tạm ngưng"/>
                                    <Button Content="✓" Width="24" Height="24" FontSize="10" Margin="1"
                                            Command="{Binding StopCommand}" ToolTip="Kết thúc"/>
                                    <Button Content="🗑" Width="24" Height="24" FontSize="10" Margin="1"
                                            Command="{Binding DeleteCommand}" ToolTip="Xóa"/>
                                </WrapPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Margin="0,4,0,0" FontSize="10" Foreground="#555">
                <Run Text="Tổng: "/><Run Text="{Binding TodoTotal, Mode=OneWay}"/>
                <Run Text=" | Xong: "/><Run Text="{Binding TodoDone, Mode=OneWay}"/>
                <Run Text=" | Đang: "/><Run Text="{Binding TodoRunning, Mode=OneWay}"/>
                <Run Text=" | Tổng giờ: "/><Run Text="{Binding TodoTotalElapsed, Mode=OneWay}"/>
            </TextBlock>

            <!-- ── Business Logic ────────────────────────────────────── -->
            <TextBlock Text="── 💼 Business Logic ──" Style="{StaticResource SectionLabel}"/>
            <TextBox Text="{Binding BusinessLogic, UpdateSourceTrigger=PropertyChanged}"
                     Height="70" FontSize="11" Padding="4" AcceptsReturn="True"
                     TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>

            <!-- ── Commit Message ────────────────────────────────────── -->
            <TextBlock Text="── 🔀 Commit Message ──" Style="{StaticResource SectionLabel}"/>
            <DockPanel Margin="0,0,0,4">
                <Button DockPanel.Dock="Right" Content="↺" Width="30" Height="50" FontSize="13"
                        Command="{Binding RegenerateCommitCommand}" Margin="4,0,0,0" ToolTip="Regenerate"/>
                <TextBox Text="{Binding CommitMessage, UpdateSourceTrigger=PropertyChanged}"
                         Height="50" FontSize="11" FontFamily="Consolas" Padding="4"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
            </DockPanel>

            <!-- ── Actions ───────────────────────────────────────────── -->
            <Separator Margin="0,10,0,6"/>
            <WrapPanel>
                <Button Content="🚀 Push &amp; Complete" Height="32" FontSize="11" FontWeight="SemiBold"
                        Padding="10,0" Margin="0,0,4,4" Command="{Binding PushAndCompleteCommand}"/>
                <Button Content="⏸ Save &amp; Pause" Height="32" FontSize="11"
                        Padding="10,0" Margin="0,0,4,4" Command="{Binding SaveAndPauseCommand}"/>
            </WrapPanel>
            <WrapPanel Margin="0,2,0,0">
                <Button Content="📚 Lịch sử" Style="{StaticResource ActionBtn}"
                        x:Name="BtnHistory" Click="BtnHistory_Click"/>
                <Button Content="📁 Projects" Style="{StaticResource ActionBtn}"
                        x:Name="BtnProjectHelper" Click="BtnProjectHelper_Click"
                        ToolTip="Mở Project Helper — danh sách .sln và .csproj"/>
                <Button Content="⚙ Settings" Style="{StaticResource ActionBtn}"
                        x:Name="BtnSettings" Click="BtnSettings_Click"/>
            </WrapPanel>
            <Border BorderBrush="#EEE" BorderThickness="0,1,0,0" Margin="0,8,0,0" Padding="0,6,0,0">
                <WrapPanel>
                    <Button Content="📄 Open Log"    Style="{StaticResource UtilBtn}"
                            x:Name="BtnOpenLog" Click="BtnOpenLog_Click"/>
                    <Button Content="📋 Open Config" Style="{StaticResource UtilBtn}"
                            x:Name="BtnOpenConfig" Click="BtnOpenConfig_Click"/>
                </WrapPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
