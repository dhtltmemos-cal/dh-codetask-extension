<Window x:Class="DhCodetaskExtension.ToolWindows.PauseReasonDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="⏸ Lý do tạm ngưng"
        Width="320" SizeToContent="Height" ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen" ShowInTaskbar="False"
        Topmost="True"
        Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">
    <StackPanel Margin="16,14,16,14">
        <TextBlock Text="Chọn lý do tạm ngưng:" FontSize="12" FontWeight="SemiBold"
                   Margin="0,0,0,10"/>

        <StackPanel x:Name="ReasonPanel" Margin="0,0,0,8"/>

        <TextBlock Text="Hoặc nhập lý do khác:" FontSize="11" Foreground="#666" Margin="0,4,0,4"/>
        <TextBox x:Name="TxtCustom" Height="26" FontSize="11" Padding="4,2"
                 VerticalContentAlignment="Center" Margin="0,0,0,12"
                 ToolTip="Nhập lý do tùy chỉnh (để trống nếu đã chọn ở trên)"/>

        <Separator Margin="0,0,0,8"/>
        <DockPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Content="Xác nhận" Width="80" Height="28" FontWeight="SemiBold"
                        FontSize="11" Margin="0,0,8,0" IsDefault="True" Click="BtnOk_Click"/>
                <Button Content="Huỷ" Width="60" Height="28" FontSize="11"
                        IsCancel="True" Click="BtnCancel_Click"/>
            </StackPanel>
        </DockPanel>
    </StackPanel>
</Window>
